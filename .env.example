# AutoShowTracker Environment Configuration
# Copy this file to .env and fill in your values.

# REQUIRED: TMDb API key (get one free at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=

# OPTIONAL: YouTube Data API v3 key (for YouTube series/playlist detection)
YOUTUBE_API_KEY=

# OPTIONAL: Override the default data directory (~/.show-tracker)
# ST_DATA_DIR=~/.show-tracker

# OPTIONAL: Override the ActivityWatch port (default 5600)
# ST_ACTIVITYWATCH_PORT=5600

# OPTIONAL: Override the media service API port (default 7600)
# ST_MEDIA_SERVICE_PORT=7600
